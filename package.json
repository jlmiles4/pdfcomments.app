{
  "name": "pdf-annotation-extractor",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && cp node_modules/pdfjs-dist/build/pdf.worker.min.mjs out/",
    "start": "next start",
    "lint": "eslint src/",
    "postinstall": "cp node_modules/pdfjs-dist/build/pdf.worker.min.mjs public/",
    "deploy:s3": "bash -c 'set -a && source .env && aws s3 sync out/ \"s3://$S3_BUCKET\" --delete'",
    "invalidate": "bash -c 'set -a && source .env && aws cloudfront create-invalidation --distribution-id \"$CLOUDFRONT_DISTRIBUTION_ID\" --paths \"/*\"'",
    "send-it": "pnpm build && pnpm deploy:s3 && pnpm invalidate"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.10"
    }
  }
}
