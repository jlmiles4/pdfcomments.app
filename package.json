{
  "name": "pdf-annotation-extractor",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && cp node_modules/pdfjs-dist/build/pdf.worker.min.mjs out/",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "cp node_modules/pdfjs-dist/build/pdf.worker.min.mjs public/",
    "deploy:s3": "bash -c 'set -a && source .env && aws s3 sync out/ s3://$S3_BUCKET --delete'",
    "invalidate": "bash -c 'set -a && source .env && aws cloudfront create-invalidation --distribution-id $CLOUDFRONT_DISTRIBUTION_ID --paths \"/*\"'",
    "send-it": "pnpm build && pnpm deploy:s3 && pnpm invalidate"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "pdfjs-dist": "^4.4.0",
    "lucide-react": "^0.400.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^20.12.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0"
  }
}
